# ====== AI Provider 配置 ======
# 选择 AI 提供方：anthropic | gemini
AI_PROVIDER=anthropic

# --- Anthropic (Claude) ---
# 申请：https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
ANTHROPIC_MODEL=claude-opus-4-7

# --- Google Gemini（可选，AI_PROVIDER=gemini 时使用）---
# 申请：https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# 复制本文件为 .env.local 并填入你的 key：
#   cp .env.example .env.local
# .env.local 已被 .gitignore 忽略，不会提交。
